# === GESTORE BLUETOOTH ROFI ===

# Stato attuale del Bluetooth
bluetooth_power_status=$(bluetoothctl show | awk '/Powered/ {print ($2=="yes" ? "enabled" : "disabled")}')

# Ottieni la connessione attiva con nome e tipo
bluetooth_status=$(bluetoothctl devices Connected | grep -q . && echo "connected" || echo "disconnected")

# Mostra il menù
# Se il Bluetooth è disabilitato, mostra solo l'opzione per abilitarlo
if [ "$bluetooth_power_status" == "disabled" ]; then
    choice=$(echo -e "Bluetooth: $bluetooth_power_status\n--------------------\nExit" | rofi -dmenu -i -p "Gestione Bluetooth")
else
    choice=$(echo -e "Bluetooth: $bluetooth_power_status\nStatus: $bluetooth_status\n--------------------\nScan near devices\nOpen Bluetooth Manager\n--------------------\nExit" | rofi -dmenu -i -p "Gestione Bluetooth")
fi

# Gestione scelte
case "$choice" in
    "Bluetooth: enabled")
        bluetoothctl power off
        ;;
    "Bluetooth: disabled")
        bluetoothctl power on
        exec "$HOME/.config/rofi/Bluetooth/rofi-bluetooth"
        ;;
    "Status: "*)
        exec "$HOME/.config/rofi/Bluetooth/rofi-bluetooth-status"
        ;;
    "Scan near devices")
        exec "$HOME/.config/rofi/Bluetooth/rofi-bluetooth-scan"
        ;;
    "Open Bluetooth Manager")
        exec blueman-manager
        ;;
    *)
        exit 0
        ;;
esac