#!/bin/bash

# === GESTORE MOVIMENTO MONITOR ROFI ===

MONITOR_CONF="$HOME/.config/hypr/monitor.conf"

# Funzione per ottenere i dati dei monitor tramite hyprctl
get_monitor_data() {
    hyprctl monitors -j
}

# Funzione per ottenere larghezza e altezza di un monitor specifico
get_dim() {
    local name=$1
    local axis=$2 # "width" o "height"
    get_monitor_data | jq -r ".[] | select(.name == \"$name\") | .$axis"
}

# Funzione per ottenere monitor ordinati (eDP-1 sempre per primo)
get_monitors(){
    local mons=($(hyprctl monitors | grep "Monitor" | grep -v "disabled" | awk '{print $2}'))
    local sorted=()

    for m in "${mons[@]}"; do
        [[ "$m" == "eDP-1" ]] && sorted+=("$m")
    done
    for m in "${mons[@]}"; do
        [[ "$m" != "eDP-1" ]] && sorted+=("$m")
    done

    echo "${sorted[@]}"
}

# Funzione per refresh completo in caso di mirror
refresh_hyprland(){
    for m in $(hyprctl monitors | grep "Monitor" | awk '{print $2}'); do
        hyprctl keyword monitor "$m,disable"
    done
    sleep 0.3
    hyprctl reload
    sleep 0.3
    hyprctl dispatch dpms on
}

# Funzione per controllare se è attivo il mirroring
is_mirrored(){
    if grep -q "mirror" "$MONITOR_CONF"; then
        return 0
    else
        return 1
    fi
}

# Funzione principale per il posizionamento
monitor_positioning(){
    local direction=$1
    
    if is_mirrored; then
        > "$MONITOR_CONF"
        refresh_hyprland
    else
        > "$MONITOR_CONF"
    fi

    local monitors=($(get_monitors))
    
    # Prendiamo le dimensioni di eDP-1 per calcolare Right e Down
    local edp_w=$(get_dim "eDP-1" "width")
    local edp_h=$(get_dim "eDP-1" "height")

    for m in "${monitors[@]}"; do
        if [[ "$m" == "eDP-1" ]]; then
            # Il monitor del laptop è sempre l'origine
            echo "monitor = $m,preferred,0x0,1" >> "$MONITOR_CONF"
        else
            # Dimensioni del monitor esterno corrente
            local ext_w=$(get_dim "$m" "width")
            local ext_h=$(get_dim "$m" "height")

            case "$direction" in
                "Up")
                    # Sopra eDP-1: y deve essere -altezza_monitor_esterno
                    echo "monitor = $m,preferred,0x-$ext_h,1" >> "$MONITOR_CONF"
                    ;;
                "Down")
                    # Sotto eDP-1: y inizia dove finisce eDP-1
                    echo "monitor = $m,preferred,0x$edp_h,1" >> "$MONITOR_CONF"
                    ;;
                "Left")
                    # Sinistra eDP-1: x deve essere -larghezza_monitor_esterno
                    echo "monitor = $m,preferred,-${ext_w}x0,1" >> "$MONITOR_CONF"
                    ;;
                "Right")
                    # Destra eDP-1: x inizia dove finisce eDP-1
                    echo "monitor = $m,preferred,${edp_w}x0,1" >> "$MONITOR_CONF"
                    ;;
            esac
        fi
    done

    hyprctl reload
}

# --- LOGICA DI ESECUZIONE ---

# Mostra il menu Rofi
choice=$(echo -e "Up\nRight\nDown\nLeft\n--------------------\nBack\nExit" | rofi -dmenu -i -p "Posizione monitor esterno rispetto a eDP-1")

case "$choice" in
    "Up")
        monitor_positioning "Up"
        ;;
    "Down")
        monitor_positioning "Down"
        ;;
    "Left")
        monitor_positioning "Left"
        ;;
    "Right")
        monitor_positioning "Right"
        ;;
    "Back")
        # Assicurati che il percorso al file principale sia corretto
        exec "$HOME/.config/rofi/Monitor/rofi-monitor"
        ;;
    *)
        exit 0
        ;;
esac